{
  "name": "leads-scraper-ig",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node --env-file-if-exists=.env.local scripts/reset-stuck-jobs.mjs",
    "dev": "concurrently -k -n next,inngest -c cyan,magenta \"npm:dev:web\" \"npm:dev:inngest\"",
    "dev:web": "next dev -p 3000",
    "dev:inngest": "inngest dev -u http://localhost:3000/api/inngest",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . && rm -rf .next && next build",
    "inngest:dev": "inngest dev -u http://localhost:3000/api/inngest",
    "db:push": "supabase db push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@playwright/test": "^1.61.0",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "imapflow": "^1.4.0",
    "inngest": "^3.27.0",
    "lucide-react": "^0.460.0",
    "mailparser": "^3.9.9",
    "next": "^15.1.0",
    "nodemailer": "^8.0.7",
    "openai": "^4.77.0",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.1.0",
    "inngest-cli": "^1.27.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3"
  }
